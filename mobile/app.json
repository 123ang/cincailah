{
  "expo": {
    "name": "Cincailah",
    "slug": "cincailah",
    "scheme": "jiakhami",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5A00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-audio",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF5A00",
          "sounds": [
            "./assets/sounds/winner.mp3"
          ]
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Cincailah to use Face ID for quick sign-in."
        }
      ],
      "expo-updates",
      "@sentry/react-native",
      "expo-asset",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://cincailah.suntzutechnologies.com",
      "sentryDsn": "",
      "eas": {
        "projectId": "377df96a-a84c-4c03-bd17-ddc4813f2a89"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/377df96a-a84c-4c03-bd17-ddc4813f2a89"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "jiak-hami",
    "android": {
      "package": "com.jiakhami.cincailah",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FF5A00"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.jiakhami.cincailah",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Cincailah uses Face ID for quick, secure sign-in."
      }
    }
  }
}
