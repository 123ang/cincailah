# Environment Variables Template
# Copy this to .env and fill in your values

# Database connection string for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/cincailah?schema=public"

# Session secret for iron-session (generate a strong random string at least 32 chars)
SESSION_SECRET="change-this-to-a-secure-random-string-at-least-32-characters-long"

# --- Email (pick ONE transport) ---
#
# Option A — Zoho Mail SMTP (recommended if you already use Zoho for your domain)
# Typical Zoho SMTP:
#   SMTP_HOST=smtp.zoho.com
#   SMTP_PORT=465   (SSL)  -> set SMTP_SECURE=true
#   OR
#   SMTP_PORT=587   (STARTTLS) -> set SMTP_SECURE=false
#
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="admin@suntzutechnologies.com"
SMTP_PASS="your-zoho-app-specific-password"

# Must match an address Zoho allows you to send as (usually the SMTP_USER mailbox)
EMAIL_FROM="Cincailah <admin@suntzutechnologies.com>"

# Option B — Resend (optional; used only if SMTP is not fully configured)
# Get a key at resend.com. Leave blank if you use Zoho SMTP above.
RESEND_API_KEY=""

# Public app URL (used in email links, QR codes, share URLs)
# In production: "https://cincailah.com"
# In development: "http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# JWT secret for mobile app token auth (POST /api/auth/token)
# If not set, falls back to SESSION_SECRET — set explicitly in production
JWT_SECRET="change-this-to-a-secure-random-jwt-secret-32-chars-min"

# Log level: debug | info | warn | error (defaults: debug in dev, info in prod)
LOG_LEVEL=""

# Cron auth secret (required for /api/cron/reminders)
CRON_SECRET="change-this-cron-secret"

# Web Push VAPID keypair (optional; required for browser push subscribe/send)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# PostHog (optional; enables analytics events like spin/reroll/vote/signup)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# Sentry DSN (optional; enables runtime error forwarding)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
